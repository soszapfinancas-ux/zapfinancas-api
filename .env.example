# ── Servidor ──────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Banco de Dados ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zapfinancas
DB_USER=postgres
DB_PASSWORD=SUA_SENHA_AQUI

# ── Hotmart ───────────────────────────────────────
# IDs dos produtos no Hotmart (encontre em Produtos > seu produto > Configurações)
HOTMART_PRODUCT_BASE_ID=1234567
HOTMART_PRODUCT_ORDERBUMP_ID=7654321
# Token secreto para validar webhooks (Hotmart > Ferramentas > Webhooks)
HOTMART_HOTTOK=SEU_HOTTOK_AQUI

# ── UAZAPI (WhatsApp) ─────────────────────────────
# Usado pelo job de lembretes para enviar mensagens agendadas
UAZAPI_BASE_URL=https://sua-instancia.uazapi.com
UAZAPI_TOKEN=seu-token-uazapi

# ── E-mail (relatórios PDF/Excel) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=ZapFinanças <seu@email.com>

# ── Admin ─────────────────────────────────────────
# Token fixo para acessar rotas /admin (mude para algo seguro)
ADMIN_TOKEN=zapfinancas-admin-2025

# ── Painel ────────────────────────────────────────
APP_URL=https://zapfinancas.orbitarosa.com
